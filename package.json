{
  "name": "atlas-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Vertical Atlas demo for public-biotech diligence research.",
  "scripts": {
    "research": "tsx src/index.ts",
    "preresearch": "node -e \"require('node:fs').mkdirSync('reports',{recursive:true})\"",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.67",
    "@steel-dev/atlas": "^0.1.0",
    "ai": "^6.0.194",
    "cheerio": "^1.0.0",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.16.0"
  }
}
