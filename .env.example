# Required for the default hybrid model profile.
ZAI_API_KEY=
OPENAI_API_KEY=

# Required by SEC EDGAR. Use a real contact address.
ATLAS_SEC_EMAIL=you@example.com

# Optional search providers. If unset, the demo still uses EDGAR, PubMed,
# and ClinicalTrials.gov, but broader web context will be limited.
TAVILY_API_KEY=
EXA_API_KEY=
BRAVE_API_KEY=

# Optional fetch escalation for JavaScript-rendered or hostile pages.
STEEL_API_KEY=

# Model routing knobs.
MODEL_PROFILE=hybrid
GLM_MODEL=glm-5.2
OPENAI_VERIFY_MODEL=gpt-5.5
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
